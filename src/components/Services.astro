---
const services = [
  {
    icon: "&#127969;",
    title: "House Sitting",
    description:
      "We stay in your home overnight, keeping it safe, secure, and exactly as you left it. Perfect for when you're travelling or away for work.",
    price: "£25",
  },
  {
    icon: "&#128021;",
    title: "Dog Sitting",
    description:
      "Your dog stays at home in their own environment with us there for walks, feeding, play and all the belly rubs they deserve.",
    price: "£25",
  },
  {
    icon: "&#128062;",
    title: "All Pets Welcome",
    description:
      "Cats, dogs, rabbits, birds — if they're part of your family, they're welcome. We'll care for all your animals as a package.",
    price: "£25",
  },
];
---

<section id="services">
  <div class="section-inner">
    <p class="section-label">What We Offer</p>
    <h2 class="section-title">Our Services</h2>
    <div class="divider"></div>

    <div class="services-grid">
      {
        services.map((service) => (
          <div class="service-card">
            <span class="service-icon" set:html={service.icon} />
            <h3>{service.title}</h3>
            <p>{service.description}</p>
            <div class="service-price">
              <span class="price-from">from</span>
              <span class="price-amount">{service.price}</span>
              <span class="price-period">/ night</span>
            </div>
          </div>
        ))
      }
    </div>

    <div class="pricing-note">
      &#128155; &nbsp; Our rates are always a fraction of kennel or cattery costs
      — and your pets get to stay happy at home. Prices are flexible and
      discussed based on your dates, location, and number of pets. Get in touch
      for a tailored quote.
    </div>
  </div>
</section>

<style>
  section {
    padding: 80px 48px;
    background: var(--cream);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-bottom: 32px;
  }

  .service-card {
    background: var(--warm-white);
    border: 1px solid rgba(200, 150, 62, 0.15);
    border-radius: 12px;
    padding: 36px 28px;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(44, 26, 14, 0.08);
  }

  .service-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 16px;
  }

  .service-card h3 {
    font-family: "Playfair Display", serif;
    font-size: 1.25rem;
    color: var(--brown-dark);
    margin-bottom: 12px;
  }

  .service-card p {
    color: var(--text-soft);
    line-height: 1.7;
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .service-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .price-from {
    font-size: 0.75rem;
    color: var(--text-soft);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .price-amount {
    font-family: "Playfair Display", serif;
    font-size: 1.6rem;
    color: var(--gold);
    font-weight: 700;
  }

  .price-period {
    font-size: 0.8rem;
    color: var(--text-soft);
  }

  .pricing-note {
    background: rgba(200, 150, 62, 0.08);
    border-left: 3px solid var(--gold);
    padding: 20px 24px;
    border-radius: 0 8px 8px 0;
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    section {
      padding: 60px 24px;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
