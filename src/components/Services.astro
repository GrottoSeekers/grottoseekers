---
const services = [
  {
    icon: "&#128054;",
    title: "Pet Sitting",
    description:
      "Your pets stay at home in their own environment while we move in to care for them. Walks, feeding, play, cuddles — everything they need to feel safe and loved while you're away.",
  },
  {
    icon: "&#127969;",
    title: "House Sitting",
    description:
      "We stay in your home overnight, keeping it safe, secure, and exactly as you left it. Perfect for when you're travelling or away for work — come back to a spotless home.",
  },
];
---

<section id="services">
  <div class="section-inner">
    <p class="section-label">What We Offer</p>
    <h2 class="section-title">Our Services</h2>
    <div class="divider"></div>

    <div class="services-grid">
      {
        services.map((service) => (
          <div class="service-card">
            <span class="service-icon" set:html={service.icon} />
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </div>
        ))
      }
    </div>

    <div class="pricing-note">
      Every home and every pet is different, so our pricing is tailored to your
      needs. We'll discuss your dates, location, and requirements to find an
      arrangement that works for everyone. <a href="#enquiry">Get in touch</a> for
      a personalised quote.
    </div>
  </div>
</section>

<style>
  section {
    padding: 80px 48px;
    background: var(--cream);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    margin-bottom: 32px;
  }

  .service-card {
    background: var(--warm-white);
    border: 1px solid rgba(200, 150, 62, 0.15);
    border-radius: 12px;
    padding: 36px 28px;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(44, 26, 14, 0.08);
  }

  .service-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 16px;
  }

  .service-card h3 {
    font-family: "Playfair Display", serif;
    font-size: 1.25rem;
    color: var(--brown-dark);
    margin-bottom: 12px;
  }

  .service-card p {
    color: var(--text-soft);
    line-height: 1.7;
    font-size: 0.9rem;
  }

  .pricing-note {
    background: rgba(200, 150, 62, 0.08);
    border-left: 3px solid var(--gold);
    padding: 20px 24px;
    border-radius: 0 8px 8px 0;
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .pricing-note a {
    color: var(--gold);
    font-weight: 600;
    text-decoration: none;
  }

  .pricing-note a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    section {
      padding: 60px 24px;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
