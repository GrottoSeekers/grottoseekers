---
const heroImages = [
  { src: "/grottoseekers/images/callum-niamh-wedding.jpg", alt: "Callum and Niamh at sunset" },
  { src: "/grottoseekers/images/chester.jpg", alt: "Chester the spaniel cuddling on the sofa" },
  { src: "/grottoseekers/images/callum-niamh-dinner.jpg", alt: "Callum and Niamh at seaside dinner" },
  { src: "/grottoseekers/images/zeus.jpg", alt: "Callum with Zeus" },
  { src: "/grottoseekers/images/callum-niamh-villa.jpg", alt: "Callum and Niamh at a villa" },
  { src: "/grottoseekers/images/hero-ted.jpg", alt: "Hero and Ted relaxing" },
];
---

<section class="hero">
  <div class="hero-slides">
    {heroImages.map((img, i) => (
      <div class={`hero-slide ${i === 0 ? "active" : ""}`} data-index={i}>
        <img src={img.src} alt={img.alt} loading={i === 0 ? "eager" : "lazy"} />
      </div>
    ))}
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <p class="hero-badge">UK & Australia</p>
    <h1>Grotto<br /><em>Sitters</em></h1>
    <p class="hero-names">Callum Disley & Niamh Roche</p>
    <p class="hero-tagline">
      <em>Trusted house & pet sitters, wherever in the world you call home.</em>
    </p>
    <a href="#enquiry" class="btn-primary">Book Us Today</a>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLDivElement>(".hero-slide");
  let current = 0;

  function nextSlide() {
    slides[current].classList.remove("active");
    current = (current + 1) % slides.length;
    slides[current].classList.add("active");
  }

  setInterval(nextSlide, 5000);
</script>

<style>
  .hero {
    position: relative;
    height: 85vh;
    min-height: 520px;
    max-height: 800px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    text-align: center;
  }

  /* ── Background slideshow ── */
  .hero-slides {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
  }

  .hero-slide.active {
    opacity: 1;
  }

  .hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  /* ── Dark overlay for text contrast ── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to bottom,
      rgba(20, 12, 5, 0.35) 0%,
      rgba(20, 12, 5, 0.55) 50%,
      rgba(20, 12, 5, 0.7) 100%
    );
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 680px;
    padding: 0 24px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: var(--gold-light);
    padding: 8px 24px;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 24px;
    border: 1px solid rgba(232, 185, 106, 0.25);
  }

  h1 {
    font-family: "Playfair Display", serif;
    font-size: 5rem;
    color: #fff;
    line-height: 1;
    margin-bottom: 16px;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
  }

  h1 em {
    color: var(--gold-light);
    font-style: italic;
  }

  .hero-names {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-bottom: 14px;
  }

  .hero-tagline {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto 32px;
  }

  .hero-tagline em {
    font-family: "Playfair Display", serif;
    font-size: 1.2rem;
  }

  .btn-primary {
    display: inline-block;
    background: var(--gold);
    color: #fff;
    padding: 16px 44px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.3s ease, transform 0.2s ease;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    transform: translateY(-1px);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero {
      height: 75vh;
      min-height: 460px;
    }

    h1 {
      font-size: 3.4rem;
    }

    .hero-tagline {
      font-size: 1rem;
    }

    .hero-tagline em {
      font-size: 1.05rem;
    }

    .btn-primary {
      padding: 14px 36px;
    }
  }
</style>
