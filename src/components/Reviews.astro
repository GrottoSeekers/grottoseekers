<section id="reviews">
  <div class="section-inner">
    <p class="section-label">What People Say</p>
    <h2 class="section-title">Over 40 five-star reviews.</h2>
    <div class="divider"></div>

    <div class="stars-row">
      <span class="star">&#9733;</span>
      <span class="star">&#9733;</span>
      <span class="star">&#9733;</span>
      <span class="star">&#9733;</span>
      <span class="star">&#9733;</span>
      <span class="stars-label">5.0 across all platforms</span>
    </div>

    <div class="reviews-track-wrapper">
      <div class="reviews-track" id="reviewsTrack">
        {
          reviews.map((review) => (
            <div class="review-card">
              <div class="review-stars">
                <span class="star">&#9733;</span>
                <span class="star">&#9733;</span>
                <span class="star">&#9733;</span>
                <span class="star">&#9733;</span>
                <span class="star">&#9733;</span>
              </div>
              <p class="review-text">"{review.text}"</p>
              <div class="review-author">
                <div class="review-avatar">{review.initials}</div>
                <div>
                  <div class="review-name">{review.name}</div>
                  <div class="review-platform">{review.platform}</div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="reviews-nav">
      <button class="rev-btn" id="prevBtn">&larr;</button>
      <button class="rev-btn" id="nextBtn">&rarr;</button>
      <div class="rev-dots" id="revDots"></div>
    </div>
  </div>
</section>

<style>
  section {
    padding: 80px 48px;
    background: var(--warm-white);
  }

  .stars-row {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 32px;
  }

  .star {
    color: var(--gold);
    font-size: 1.2rem;
  }

  .stars-label {
    color: var(--gold-pale);
    font-size: 0.85rem;
    margin-left: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .reviews-track-wrapper {
    overflow: hidden;
    margin-bottom: 24px;
  }

  .reviews-track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s ease;
  }

  .review-card {
    min-width: 340px;
    max-width: 340px;
    background: var(--cream);
    border: 1px solid rgba(200, 150, 62, 0.12);
    border-radius: 12px;
    padding: 28px;
    flex-shrink: 0;
  }

  .review-stars {
    margin-bottom: 14px;
  }

  .review-stars .star {
    font-size: 0.95rem;
  }

  .review-text {
    color: var(--text-soft);
    font-size: 0.88rem;
    line-height: 1.75;
    margin-bottom: 20px;
    font-style: italic;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--gold);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .review-name {
    font-weight: 700;
    color: var(--brown-dark);
    font-size: 0.9rem;
  }

  .review-platform {
    color: var(--text-soft);
    font-size: 0.78rem;
  }

  .reviews-nav {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .rev-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(200, 150, 62, 0.3);
    background: transparent;
    color: var(--brown-mid);
    font-size: 1rem;
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .rev-btn:hover {
    background: var(--gold);
    color: #fff;
    border-color: var(--gold);
  }

  .rev-dots {
    display: flex;
    gap: 6px;
    margin-left: 8px;
  }

  .rev-dots :global(.rev-dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold-pale);
    cursor: pointer;
    transition: background 0.2s;
  }

  .rev-dots :global(.rev-dot.active) {
    background: var(--gold);
  }

  @media (max-width: 768px) {
    section {
      padding: 60px 24px;
    }

    .review-card {
      min-width: 280px;
      max-width: 280px;
    }
  }
</style>

<script>
  function initReviewsCarousel() {
    const track = document.getElementById("reviewsTrack") as HTMLElement;
    const cards = track?.querySelectorAll(".review-card");
    const dotsContainer = document.getElementById("revDots") as HTMLElement;
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");

    if (!track || !cards || !dotsContainer) return;

    let current = 0;

    function getVisibleCount() {
      if (window.innerWidth >= 900) return 3;
      if (window.innerWidth >= 600) return 2;
      return 1;
    }

    function getCardWidth() {
      return (cards[0] as HTMLElement).offsetWidth + 24;
    }

    function getMaxIndex() {
      return Math.max(0, cards.length - getVisibleCount());
    }

    function buildDots() {
      dotsContainer.innerHTML = "";
      const total = getMaxIndex() + 1;
      for (let i = 0; i < total; i++) {
        const d = document.createElement("div");
        d.className = "rev-dot" + (i === current ? " active" : "");
        d.addEventListener("click", () => goTo(i));
        dotsContainer.appendChild(d);
      }
    }

    function update() {
      if (current > getMaxIndex()) current = getMaxIndex();
      track.style.transform = `translateX(-${current * getCardWidth()}px)`;
      dotsContainer.querySelectorAll(".rev-dot").forEach((d, i) => {
        d.classList.toggle("active", i === current);
      });
    }

    function goTo(i: number) {
      current = Math.max(0, Math.min(i, getMaxIndex()));
      update();
    }

    prevBtn?.addEventListener("click", () => goTo(current - 1));
    nextBtn?.addEventListener("click", () => goTo(current + 1));

    window.addEventListener("resize", () => {
      buildDots();
      update();
    });

    buildDots();
    update();
  }

  document.addEventListener("DOMContentLoaded", initReviewsCarousel);
  document.addEventListener("astro:page-load", initReviewsCarousel);
</script>
