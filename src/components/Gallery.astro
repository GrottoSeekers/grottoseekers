---

<section id="gallery">
  <div class="section-inner">
    <p class="section-label">In Good Hands</p>
    <h2 class="section-title">The ones we've loved</h2>
    <div class="divider"></div>
    <p class="gallery-intro">
      From Sydney to the English countryside — every sit brings new friends.
      Here are some of the wonderful animals we've had the pleasure of caring
      for.
    </p>

    <div class="pet-grid">
      {
        pets.map((pet, petIdx) => (
          <div class="pet-card" data-pet-index={petIdx}>
            <div class="pet-carousel">
              <div class="pet-images">
                {pet.images.map((src, imgIdx) => (
                  <img
                    src={src}
                    alt={pet.alt[imgIdx]}
                    loading="lazy"
                    class={imgIdx === 0 ? "active" : ""}
                  />
                ))}
              </div>
              {pet.images.length > 1 && (
                <button class="carousel-btn carousel-prev">&lsaquo;</button>
                <button class="carousel-btn carousel-next">&rsaquo;</button>
                <div class="carousel-dots">
                  {pet.images.map((_, i) => (
                    <span class={`carousel-dot ${i === 0 ? "active" : ""}`} data-index={i} />
                  ))}
                </div>
              )}
            </div>
            <div class="pet-info">
              <span class="pet-name">{pet.name}</span>
              {pet.owner && <span class="pet-owner">{pet.owner}</span>}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  section {
    padding: 80px 48px;
    background: var(--cream);
  }

  .gallery-intro {
    color: var(--text-soft);
    margin-bottom: 40px;
    max-width: 600px;
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .pet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .pet-card {
    background: var(--warm-white);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(200, 150, 62, 0.1);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .pet-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .pet-carousel {
    position: relative;
    overflow: hidden;
  }

  .pet-images {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
  }

  .pet-images img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .pet-images img.active {
    opacity: 1;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.85);
    border: none;
    color: var(--brown-dark);
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 2;
    line-height: 1;
  }

  .pet-card:hover .carousel-btn {
    opacity: 1;
  }

  .carousel-btn:hover {
    background: var(--gold);
    color: #fff;
  }

  .carousel-prev {
    left: 8px;
  }

  .carousel-next {
    right: 8px;
  }

  .carousel-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
  }

  .carousel-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: background 0.2s;
  }

  .carousel-dot.active {
    background: #fff;
  }

  .pet-info {
    padding: 16px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .pet-name {
    font-family: var(--heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--brown-dark);
  }

  .pet-owner {
    font-size: 0.8rem;
    color: var(--text-soft);
    font-style: italic;
  }

  @media (max-width: 768px) {
    section {
      padding: 60px 24px;
    }

    .pet-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }
  }

  @media (max-width: 480px) {
    .pet-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function initPetCarousels() {
    document.querySelectorAll(".pet-card").forEach((card) => {
      const images = card.querySelectorAll(".pet-images img");
      const dots = card.querySelectorAll(".carousel-dot");
      const prevBtn = card.querySelector(".carousel-prev");
      const nextBtn = card.querySelector(".carousel-next");

      if (images.length <= 1) return;

      let current = 0;

      function show(idx: number) {
        images.forEach((img) => img.classList.remove("active"));
        dots.forEach((dot) => dot.classList.remove("active"));
        current = ((idx % images.length) + images.length) % images.length;
        images[current].classList.add("active");
        dots[current]?.classList.add("active");
      }

      prevBtn?.addEventListener("click", () => show(current - 1));
      nextBtn?.addEventListener("click", () => show(current + 1));
      dots.forEach((dot, i) => {
        dot.addEventListener("click", () => show(i));
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initPetCarousels);
  document.addEventListener("astro:page-load", initPetCarousels);
</script>
