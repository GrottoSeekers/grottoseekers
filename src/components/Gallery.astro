---
const base = import.meta.env.BASE_URL.replace(/\/?$/, "/");
const pets = [
  {
    src: `${base}images/zeus.jpg`,
    name: "Zeus",
    quote: "They looked after Zeus and the house impeccably. We're pretty sure Zeus was disappointed when we came home!",
    owner: "Danielle",
    platform: "TrustedHouseSitters",
  },
  {
    src: `${base}images/scuff.jpg`,
    name: "Scuff",
    quote: "Scuff is still looking in the spare room to check if his friends have really gone! We appreciated the regular updates and photos.",
    owner: "Kimberley",
    platform: "TrustedHouseSitters",
  },
  {
    src: `${base}images/alfie-1.jpg`,
    name: "Alfie",
    quote: "Alfie absolutely adores Callum and Niamh! He doesn't want to come home after! They always provide so many updates and look after him like he's their own.",
    owner: "Carissa D.",
    platform: "Rover",
  },
  {
    src: `${base}images/chester.jpg`,
    name: "Chester",
    quote: "We've been blown away by the great job they've done. Our holidays are so much more relaxed for having found them.",
    owner: "Charlotte",
    platform: "Rover",
  },
  {
    src: `${base}images/daisy-rocky.jpg`,
    name: "Daisy & Rocky",
    quote: "We came home to happy puppies and they went the extra mile. I'm so grateful our dogs were in such great hands.",
    owner: "Heather",
    platform: "TrustedHouseSitters",
  },
  {
    src: `${base}images/luffy.jpg`,
    name: "Luffy",
    quote: "Both lovely, very professional but also super friendly. He came home so content! We would absolutely use them again in a heartbeat.",
    owner: "Phillipa",
    platform: "Rover",
  },
  {
    src: `${base}images/matilda.jpg`,
    name: "Matilda",
    quote: "They took excellent care of both our dogs for 2 weeks. The dogs were exercised, loved and treated like family. You won't find better!",
    owner: "Deb",
    platform: "Rover",
  },
  {
    src: `${base}images/poppy.jpg`,
    name: "Poppy",
    quote: "We have 4 dogs, a cat, chooks and a big garden. The animals were very well looked after and happy. I would highly recommend these two.",
    owner: "Angela",
    platform: "TrustedHouseSitters",
  },
  {
    src: `${base}images/finley.jpg`,
    name: "Finley",
    quote: "Mali took to them immediately. They were loving and took great care of him, even taking him for walks in the rain.",
    owner: "Elizabeth",
    platform: "TrustedHouseSitters",
  },
  {
    src: `${base}images/hero-ted.jpg`,
    name: "Hero & Ted",
    quote: "We couldn't have asked for better pet sitters. They absolutely exceeded expectations. Bailey clearly loved them too!",
    owner: "Libby",
    platform: "TrustedHouseSitters",
  },
  {
    src: `${base}images/molly.jpg`,
    name: "Molly",
    quote: "Solly absolutely adores them both. They are reliable, trustworthy, and clearly care about his wellbeing. I couldn't recommend them highly enough.",
    owner: "Thomas James",
    platform: "Rover",
  },
];
---

<section id="gallery">
  <div class="section-inner">
    <p class="section-label">In Good Hands</p>
    <h2 class="section-title">The ones we've loved</h2>
    <div class="divider"></div>
    <p class="gallery-intro">
      From Sydney to the English countryside — every sit brings new friends.
      Here are some of the wonderful animals we've had the pleasure of caring
      for.
    </p>

    <div class="pets-grid">
      {pets.map((pet) => (
        <div class="pet-card">
          <div class="pet-image">
            <img src={pet.src} alt={pet.name} loading="lazy" />
          </div>
          <div class="pet-info">
            <h3 class="pet-name">{pet.name}</h3>
            <p class="pet-quote">"{pet.quote}"</p>
            <p class="pet-owner">— {pet.owner}, <span>{pet.platform}</span></p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 80px 48px;
    background: var(--cream);
  }

  .gallery-intro {
    color: var(--text-soft);
    margin-bottom: 40px;
    max-width: 600px;
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .pets-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .pet-card {
    background: var(--warm-white);
    border: 1px solid rgba(200, 150, 62, 0.12);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .pet-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(44, 26, 14, 0.08);
  }

  .pet-image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
  }

  .pet-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .pet-card:hover .pet-image img {
    transform: scale(1.03);
  }

  .pet-info {
    padding: 20px;
  }

  .pet-name {
    font-family: "Playfair Display", serif;
    font-size: 1.15rem;
    color: var(--brown-dark);
    margin-bottom: 8px;
  }

  .pet-quote {
    color: var(--text-soft);
    font-size: 0.85rem;
    line-height: 1.65;
    font-style: italic;
    margin-bottom: 12px;
  }

  .pet-owner {
    font-size: 0.78rem;
    color: var(--brown-mid);
    font-weight: 700;
  }

  .pet-owner span {
    color: var(--gold);
    font-weight: 400;
  }

  @media (max-width: 900px) {
    .pets-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    section {
      padding: 60px 24px;
    }

    .pets-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
    }
  }
</style>
